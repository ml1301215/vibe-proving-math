# vibe_proving — 统一编码与基础排版（减少 VS / Claude Code / 终端混用时的乱码与差异）
# 参考：https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{py,pyi}]
indent_style = space
indent_size = 4

[*.{js,mjs,cjs,ts,tsx,css,scss,html}]
indent_style = space
indent_size = 2

[*.{json,toml,yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
